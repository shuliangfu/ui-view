{
  "name": "@dreamer/ui-view",
  "version": "0.1.0",
  "workspace": [
    "docs"
  ],
  "license": "Apache-2.0",
  "description": "View framework UI components for Dreamer. Desktop and mobile with Tailwind v4 and light/dark theme.",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuliangfu/ui-view.git"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./basic": "./src/desktop/basic/mod.ts",
    "./form": "./src/desktop/form/mod.ts",
    "./config-provider": "./src/desktop/config-provider/mod.ts",
    "./data-display": "./src/desktop/data-display/mod.ts",
    "./feedback": "./src/desktop/feedback/mod.ts",
    "./layout": "./src/desktop/layout/mod.ts",
    "./navigation": "./src/desktop/navigation/mod.ts",
    "./charts": "./src/desktop/charts/mod.ts",
    "./mobile": "./src/mobile/mod.ts",
    "./mobile/basic": "./src/mobile/basic/mod.ts",
    "./mobile/form": "./src/mobile/form/mod.ts",
    "./mobile/config-provider": "./src/mobile/config-provider/mod.ts",
    "./mobile/data-display": "./src/mobile/data-display/mod.ts",
    "./mobile/feedback": "./src/mobile/feedback/mod.ts",
    "./mobile/layout": "./src/mobile/layout/mod.ts",
    "./mobile/navigation": "./src/mobile/navigation/mod.ts",
    "./mobile/charts": "./src/mobile/charts/mod.ts",
    "./plugin": "./plugin.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "styles/*.css",
      "plugin.ts",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/tests/**"
    ]
  },
  "tasks": {
    "test": "deno test -A tests/",
    "check": "deno check .",
    "fetch-tabler-icons": "deno run -A scripts/fetch-tabler-icons.ts"
  },
  "imports": {
    "@dreamer/plugin": "jsr:@dreamer/plugin@^1.0.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/test": "jsr:@dreamer/test@^1.0.15",

    "@dreamer/view": "../view/src/mod.ts",
    "@dreamer/view/portal": "../view/src/portal.ts",
    "@dreamer/view/ssr": "../view/src/mod-ssr.ts",
    "@dreamer/view/csr": "../view/src/mod-csr.ts",
    "@dreamer/view/jsx-runtime": "../view/src/jsx-runtime.ts",
    "@dreamer/view/jsx-runtime/jsx-runtime": "../view/src/jsx-runtime/jsx-runtime.ts",
    "@dreamer/view/jsx-dev-runtime": "../view/src/jsx-runtime.ts",
    "@dreamer/view/jsx-handoff": "../view/src/jsx-handoff.ts",
    "@dreamer/view/vnode-debug": "../view/src/vnode-debug.ts",
    "@dreamer/view/compiler": "../view/src/compiler/mod.ts",
    "@dreamer/view/insert-replacing": "../view/src/compiler/insert-replacing.ts",
    "@dreamer/view/optimize": "../view/src/optimize.ts",
    "@dreamer/view/jsx-compiler": "../view/src/jsx-compiler/mod.ts",
    "@dreamer/view/compiled": "../view/src/compiled.ts",
    "@dreamer/view/signal": "../view/src/signal.ts",
    "@dreamer/view/context": "../view/src/context.ts",
    "@dreamer/view/hybrid": "../view/src/mod-hybrid.ts",
    "@dreamer/view/directive": "../view/src/directive.ts",
    "@dreamer/view/reactive": "../view/src/reactive.ts",

    "tailwindcss": "npm:tailwindcss@4.1.18",
    "tailwind-merge": "npm:tailwind-merge@^2.6.1",
    "chart.js": "npm:chart.js@^4.5.1",
    "prismjs": "npm:prismjs@^1.30.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "lib": [
      "deno.window",
      "dom"
    ],
    "types": [
      "./jsx.d.ts"
    ]
  },
  "lint": {
    "include": [
      "src/",
      "plugin.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "src/shared/data-display/CodeBlock.tsx"
    ]
  }
}
