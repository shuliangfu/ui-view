{
  "name": "@dreamer/ui-view",
  "version": "1.0.0-beta.1",
  "workspace": [
    "docs"
  ],
  "license": "Apache-2.0",
  "description": "View framework UI components for Dreamer. Desktop and mobile with Tailwind v4 and light/dark theme.",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuliangfu/ui-view.git"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./basic": "./src/desktop/basic/mod.ts",
    "./form": "./src/desktop/form/mod.ts",
    "./config-provider": "./src/desktop/config-provider/mod.ts",
    "./data-display": "./src/desktop/data-display/mod.ts",
    "./feedback": "./src/desktop/feedback/mod.ts",
    "./layout": "./src/desktop/layout/mod.ts",
    "./navigation": "./src/desktop/navigation/mod.ts",
    "./charts": "./src/desktop/charts/mod.ts",
    "./mobile": "./src/mobile/mod.ts",
    "./mobile/basic": "./src/mobile/basic/mod.ts",
    "./mobile/form": "./src/mobile/form/mod.ts",
    "./mobile/config-provider": "./src/mobile/config-provider/mod.ts",
    "./mobile/data-display": "./src/mobile/data-display/mod.ts",
    "./mobile/feedback": "./src/mobile/feedback/mod.ts",
    "./mobile/layout": "./src/mobile/layout/mod.ts",
    "./mobile/navigation": "./src/mobile/navigation/mod.ts",
    "./mobile/charts": "./src/mobile/charts/mod.ts",
    "./plugin": "./plugin.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "styles/*.css",
      "plugin.ts",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/tests/**"
    ]
  },
  "test": {
    "include": [
      "tests/**/*.ts",
      "tests/**/*.tsx"
    ],
    "exclude": [
      "docs/runtime/**",
      "**/deno-cache/**"
    ]
  },
  "tasks": {
    "test": "deno test -A",
    "check": "deno check .",
    "publish:jsr": "deno publish",
    "publish:jsr:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@dreamer/markdown": "jsr:@dreamer/markdown@^1.0.1",
    "@dreamer/plugin": "jsr:@dreamer/plugin@^1.0.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/test": "jsr:@dreamer/test@^1.1.3",

    "@dreamer/view": "jsr:@dreamer/view@^2.0.1",

    "tailwindcss": "npm:tailwindcss@4.1.18",
    "tailwind-merge": "npm:tailwind-merge@^2.6.1",
    "chart.js": "npm:chart.js@^4.5.1",
    "prismjs": "npm:prismjs@^1.30.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "lib": [
      "deno.window",
      "dom"
    ]
  },
  "lint": {
    "include": [
      "src/",
      "plugin.ts",
      "tests/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "src/shared/data-display/CodeBlock.tsx"
    ]
  }
}
