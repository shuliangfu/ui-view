{
  "version": "1.0.0",
  "tasks": {
    "dev": "deno run -A src/main.ts",
    "build": "deno run -A src/main.ts --build",
    "start": "deno run -A dist/server.js"
  },
  "imports": {
    "@dreamer/dweb": "jsr:@dreamer/dweb@^3.3.1",
    "@dreamer/render": "jsr:@dreamer/render@^1.1.4",
    "@dreamer/router": "jsr:@dreamer/router@^1.1.3",
    "@dreamer/upload": "jsr:@dreamer/upload@^1.0.1",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/plugins": "jsr:@dreamer/plugins@^1.0.9",
    "@dreamer/theme": "jsr:@dreamer/theme@^1.0.1",

    "@dreamer/view": "jsr:@dreamer/view@^2.0.1",

    "@dreamer/ui-view": "../src/mod.ts",
    "@dreamer/ui-view/basic": "../src/desktop/basic/mod.ts",
    "@dreamer/ui-view/form": "../src/desktop/form/mod.ts",
    "@dreamer/ui-view/config-provider": "../src/desktop/config-provider/mod.ts",
    "@dreamer/ui-view/data-display": "../src/desktop/data-display/mod.ts",
    "@dreamer/ui-view/feedback": "../src/desktop/feedback/mod.ts",
    "@dreamer/ui-view/layout": "../src/desktop/layout/mod.ts",
    "@dreamer/ui-view/navigation": "../src/desktop/navigation/mod.ts",
    "@dreamer/ui-view/charts": "../src/desktop/charts/mod.ts",
    "@dreamer/ui-view/mobile": "../src/mobile/mod.ts",
    "@dreamer/ui-view/mobile/basic": "../src/mobile/basic/mod.ts",
    "@dreamer/ui-view/mobile/form": "../src/mobile/form/mod.ts",
    "@dreamer/ui-view/mobile/config-provider": "../src/mobile/config-provider/mod.ts",
    "@dreamer/ui-view/mobile/data-display": "../src/mobile/data-display/mod.ts",
    "@dreamer/ui-view/mobile/feedback": "../src/mobile/feedback/mod.ts",
    "@dreamer/ui-view/mobile/layout": "../src/mobile/layout/mod.ts",
    "@dreamer/ui-view/mobile/navigation": "../src/mobile/navigation/mod.ts",
    "@dreamer/ui-view/mobile/charts": "../src/mobile/charts/mod.ts",
    "@dreamer/ui-view/plugin": "../plugin.ts",

    "@dreamer/markdown": "jsr:@dreamer/markdown@^1.0.1",
    "postcss": "npm:postcss@8.4.39",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "@tailwindcss/postcss": "npm:@tailwindcss/postcss@4.1.18"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "types": [
      "jsx.d.ts"
    ]
  }
}
