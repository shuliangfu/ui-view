{
  "version": "1.0.0",
  "tasks": {
    "dev": "deno run -A src/main.ts",
    "build": "deno run -A src/main.ts --build",
    "start": "deno run -A dist/server.js"
  },
  "imports": {
    "@dreamer/dweb": "jsr:@dreamer/dweb@^3.1.9",
    "@dreamer/render": "jsr:@dreamer/render@^1.1.1",
    "@dreamer/router": "jsr:@dreamer/router@^1.1.0",
    "@dreamer/plugins": "jsr:@dreamer/plugins@^1.0.9",
    "@dreamer/view": "jsr:@dreamer/view@^1.1.5",
    "@dreamer/ui-view": "../src/mod.ts",

    "postcss": "npm:postcss@8.4.39",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "@tailwindcss/postcss": "npm:@tailwindcss/postcss@4.1.18"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "types": ["jsx.d.ts"]
  }
}
